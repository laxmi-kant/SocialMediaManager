# ==============================================================================
# AI Social Media Manager - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# --- Database ---
POSTGRES_USER=smm
POSTGRES_PASSWORD=smmpass
POSTGRES_DB=smm
DATABASE_URL=postgresql+asyncpg://smm:smmpass@localhost:5432/smm
DATABASE_URL_SYNC=postgresql://smm:smmpass@localhost:5432/smm

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-256-bit-key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

# --- Claude AI ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEFAULT_AI_MODEL=claude-haiku-4-5-20251001

# --- Twitter/X OAuth 2.0 ---
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_CALLBACK_URL=http://localhost:8000/api/v1/platforms/twitter/callback

# --- LinkedIn OAuth 2.0 ---
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_CALLBACK_URL=http://localhost:8000/api/v1/platforms/linkedin/callback

# --- Reddit OAuth (for content fetching) ---
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# --- Dev.to (optional) ---
DEVTO_API_KEY=

# --- Application ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
